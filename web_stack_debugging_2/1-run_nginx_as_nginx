#!/usr/bin/env bash
# Configure Nginx to run as nginx user and listen on port 8080

# Ensure nginx user exists
id -u nginx > /dev/null 2>&1 || useradd --no-create-home --system nginx

# Set nginx to run as nginx user
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf

# Update default site to listen on port 8080
sed -i 's/listen 80/listen 8080/g' /etc/nginx/sites-enabled/default
sed -i 's/listen \[::\]:80/listen [::]:8080/g' /etc/nginx/sites-enabled/default

# Restart nginx
nginx -s stop 2>/dev/null; nginx
